#!/usr/bin/env bash
#
# NodePress pre-push gate.
#
# GitHub Actions is disabled on this account, so this local hook is the
# automated check that runs before code leaves a machine: it type-checks both
# workspaces and runs the backend unit tests. e2e tests need a real Postgres,
# so they stay in CI / validate.sh — not here.
#
# Wired up automatically by the root `prepare` script (sets core.hooksPath).
# Skip in an emergency with `git push --no-verify`.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "[pre-push] backend type-check…"
( cd "$ROOT/backend" && npx tsc --noEmit )

echo "[pre-push] frontend type-check…"
( cd "$ROOT/frontend" && npx tsc --noEmit )

echo "[pre-push] backend unit tests…"
# Dummy test env so config/env.ts validation passes at import time. Unit tests
# mock Prisma, so no real database is touched.
( cd "$ROOT/backend" && \
  DATABASE_URL="postgresql://postgres:x@localhost:5432/test" \
  DIRECT_URL="postgresql://postgres:x@localhost:5432/test" \
  JWT_SECRET="local_pre_push_hook_test_secret_min_32_chars_xxxxxxxx" \
  CORS_ORIGIN="http://localhost:3000" \
  NODE_ENV="test" \
  npm test --silent )

echo "[pre-push] ✓ type-checks + unit tests passed"
