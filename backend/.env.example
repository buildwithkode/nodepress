# NodePress Backend — copy to .env and fill in your values
# The CLI (npx create-nodepress-app) generates this automatically.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the app (use pooled URL if using PgBouncer / Neon)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/YOUR_NODEPRESS_DATABASE"

# Direct (non-pooled) PostgreSQL URL — required by Prisma migrations.
# If not using a pooler (local Postgres / plain Neon direct URL), set to same as DATABASE_URL.
DIRECT_URL="postgresql://postgres:your_password@localhost:5432/YOUR_NODEPRESS_DATABASE"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# Allowed origin for the admin panel (no trailing slash).
# Comma-separated for multiple origins: "https://app.com,https://staging.app.com"
CORS_ORIGIN=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────

PORT=3000
APP_URL=http://localhost:3000
SITE_URL=http://localhost:5173

# Access token lifetime (default 7d). Refresh tokens always last 30 days (HttpOnly cookie, rotated on use).
# JWT_EXPIRES_IN=7d

# Logging level (debug | info | warn | error). Default: debug in dev, info in prod.
# LOG_LEVEL=info

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional. When set:
#   - AppCacheService uses Redis instead of in-memory Map (shared across instances)
#   - Socket.io uses the Redis adapter (real-time events sync across all instances)
# REDIS_URL=redis://localhost:6379

# ── S3 media storage ──────────────────────────────────────────────────────────
# Leave blank to store files locally in backend/uploads/
# STORAGE_DRIVER=s3
# STORAGE_S3_BUCKET=my-bucket
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_ENDPOINT=               # only needed for R2 / MinIO / Backblaze
# STORAGE_S3_PUBLIC_URL=             # CDN domain for public file URLs

# ── Email ─────────────────────────────────────────────────────────────────────
# Required for: password reset links, user invitation emails, form email actions.
# Without SMTP in development, the reset link is shown directly in the browser UI (no terminal digging).
# Without SMTP in production, password reset silently does nothing — configure SMTP before going live.
#
# Gmail setup: Gmail rejects your normal password over SMTP — you need a 16-char App Password.
#   1. Enable 2-Step Verification: https://myaccount.google.com/signinoptions/two-step-verification
#   2. Create an App Password:      https://myaccount.google.com/apppasswords  (choose Mail / Other)
#   3. Use that 16-char value (no spaces) as SMTP_PASS below.
#   Gmail is fine for testing (~500 msgs/day cap). For production use a provider like
#   Resend / Brevo / Mailgun / SendGrid / Postmark — same five vars, better deliverability.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false                  # true for port 465 (SSL), false for 587 (STARTTLS)
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_16_char_app_password  # Gmail App Password (https://myaccount.google.com/apppasswords) — NOT your login password
# SMTP_FROM=NodePress <noreply@yourdomain.com>
#
# Form-submission email branding (all optional — used for the email a form's
# Email action sends). Field rows use each field's label automatically.
# MAIL_BRAND_NAME=Your Company           # shown in the header + footer (default: NodePress)
# MAIL_BRAND_LOGO_URL=https://yourcdn.com/logo.png  # absolute https URL; replaces the name in the header
# MAIL_BRAND_COLOR=#4f46e5               # header background colour (hex)

# ── Spam protection — captcha for public form submissions ──────────────────────
# Each provider gives you TWO keys — do not swap them:
#   • Site Key   → goes in your WEBSITE form HTML (the widget's data-sitekey). Public. NOT here.
#   • Secret Key → goes BELOW as CAPTCHA_SECRET_KEY. Private — never put it in frontend code or git.
# Then toggle per-form: turn on the "Spam Protection (Captcha)" switch (captchaEnabled=true).
# Frontend: render the captcha widget and pass its token as `captchaToken` in the submit body.
# Note: setting CAPTCHA_PROVIDER without CAPTCHA_SECRET_KEY stops the backend from starting.
#
# Providers:
#   turnstile  — Cloudflare Turnstile (recommended — invisible, no user puzzle)
#                Dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
#   hcaptcha   — hCaptcha
#                Dashboard: https://dashboard.hcaptcha.com/
#   recaptcha  — Google reCAPTCHA v2 or v3
#                Dashboard: https://www.google.com/recaptcha/admin/create
#
# CAPTCHA_PROVIDER=turnstile
# CAPTCHA_SECRET_KEY=0x4AAAAAAA...your_server_secret_here

# ── Audit log ─────────────────────────────────────────────────────────────────
# How many days to keep audit log entries (default 90). Pruned weekly on Sunday 03:00 UTC.
# AUDIT_LOG_RETENTION_DAYS=90

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── Prometheus metrics auth ───────────────────────────────────────────────────
# Protects GET /api/metrics with a Bearer token. Leave blank for unauthenticated access.
# METRICS_TOKEN=replace_with_random_secret

# ── robots.txt ────────────────────────────────────────────────────────────────
# Comma-separated paths to add as Disallow rules in /api/robots.txt
# ROBOTS_DISALLOW=/admin,/api/private
