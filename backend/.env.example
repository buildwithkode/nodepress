# NodePress Backend — copy to .env and fill in your values
# The CLI (npx create-nodepress-app) generates this automatically.

# ── Required ──────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://postgres:your_password@localhost:5432/YOUR_NODEPRESS_DATABASE"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# Allowed origin for the admin panel (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────

PORT=3000
APP_URL=http://localhost:3000
SITE_URL=http://localhost:5173

# Redis cache (leave blank to use in-memory cache)
# REDIS_URL=redis://localhost:6379

# S3 media storage (leave blank to store files locally)
# STORAGE_DRIVER=s3
# STORAGE_S3_BUCKET=my-bucket
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_ENDPOINT=               # only needed for R2/MinIO
# STORAGE_S3_PUBLIC_URL=             # CDN domain for public file URLs

# Email — required for password reset and form email actions
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# Error tracking (Sentry)
# SENTRY_DSN=https://...

# Prometheus metrics auth (leave blank to allow unauthenticated /api/metrics)
# METRICS_TOKEN=replace_with_random_secret

# WebSocket / real-time — clients connect to ws://your-api-host/api/realtime
# No extra config needed; CORS_ORIGIN controls allowed origins.

# Logging level (debug | info | warn | error). Default: debug in dev, info in prod.
# LOG_LEVEL=info

# Direct DB URL for Prisma migrations (required when using PgBouncer connection pooling)
# DIRECT_URL="postgresql://postgres:your_password@localhost:5432/YOUR_NODEPRESS_DATABASE"
