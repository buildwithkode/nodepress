# NodePress Backend — Environment Variables
# Copy to .env and fill in your values.
# The CLI (npx create-nodepress-app) generates this with random secrets automatically.

# ── Database ──────────────────────────────────────────────────────────────────
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/nodepress"

# Direct connection (used by Prisma migrations — bypasses PgBouncer in production)
DIRECT_URL="postgresql://postgres:your_password@localhost:5432/nodepress"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# ── URLs ─────────────────────────────────────────────────────────────────────
# Allowed origin for CORS (your frontend URL — no trailing slash)
CORS_ORIGIN=http://localhost:3001

# Public URL of this backend (used to build uploaded file URLs in local storage mode)
APP_URL=http://localhost:3000

# Public URL of your site (used in sitemap.xml)
SITE_URL=http://localhost:3001

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
# Defaults to "debug" in development, "info" in production
LOG_LEVEL=info

# ── Media Storage ─────────────────────────────────────────────────────────────
# Driver: "local" (default) or "s3"
STORAGE_DRIVER=local

# S3 / Cloudflare R2 / MinIO / DigitalOcean Spaces (only needed if STORAGE_DRIVER=s3):
# STORAGE_S3_BUCKET=my-nodepress-bucket
# STORAGE_S3_REGION=us-east-1               # Use "auto" for Cloudflare R2
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_ENDPOINT=                      # Custom endpoint for R2/MinIO (leave blank for AWS)
# STORAGE_S3_PUBLIC_URL=                    # CDN domain (e.g. https://assets.example.com)

# Image processing limits
# MEDIA_MAX_DIMENSION=2400                  # Max width/height in pixels before downscaling

# ── Email (optional — required for password reset and form email actions) ─────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false                         # true for port 465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password               # Gmail: use an App Password, not your real password
# SMTP_FROM=noreply@yourdomain.com
