{
  "name": "nodepress-backend",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Karthik Paulraj / BuildWithKode <https://buildwithkode.com>",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand --forceExit"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "esModuleInterop": true
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/index.ts",
      "!**/main.ts",
      "!**/instrument.ts",
      "!**/*.module.ts",
      "!**/prisma/prisma.service.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": ["text-summary", "lcov", "json-summary"],
    "coverageThresholds": {
      "global": {
        "statements": 60,
        "branches":   50,
        "functions":  60,
        "lines":      60
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/lib-storage": "^3.1015.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.0.0",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/graphql": "^12.2.2",
    "@nestjs/throttler": "^6.5.0",
    "apollo-server-express": "^3.13.0",
    "graphql": "^16.9.0",
    "graphql-type-json": "^0.3.2",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "socket.io": "^4.8.1",
    "@prisma/client": "^5.22.0",
    "@sentry/nestjs": "^10.45.0",
    "@sentry/profiling-node": "^10.45.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.32.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
