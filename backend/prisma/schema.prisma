generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContentType {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  schema         Json
  allowedMethods Json?    // null = all enabled. e.g. ["list","read","create","update","delete"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  entries        Entry[]

  @@map("content_types")
}

model Entry {
  id            Int            @id @default(autoincrement())
  publicId      String         @unique @default(uuid())   // public-facing UUID v4 — exposed as "id" in API
  slug          String
  status        String         @default("published")       // draft | published | archived
  data          Json
  contentType   ContentType    @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  contentTypeId Int
  seo           Json?                                      // { title?, description?, image?, noIndex? }
  publishAt     DateTime?                                  // if set and in the past → auto-published by cron
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?                                  // null = active; set on soft delete
  versions      EntryVersion[]

  @@unique([contentTypeId, slug])
  @@map("entries")
}

model EntryVersion {
  id        Int      @id @default(autoincrement())
  entryId   Int
  slug      String
  data      Json
  status    String
  createdBy Int?     // userId who triggered the update
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@map("entry_versions")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  key         String    @unique
  permissions Json      // { access: "read"|"write"|"all", contentTypes: string[]|"*" }
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@map("api_keys")
}

// ─── Media Library ───────────────────────────────────────────────────────────

model Media {
  id           Int      @id @default(autoincrement())
  filename     String   @unique              // stored filename / S3 key
  webpFilename String?                       // WebP version key (images only)
  url          String                        // public URL
  webpUrl      String?                       // WebP version URL
  originalName String                        // original upload filename
  mimetype     String
  size         Int                           // bytes (after optimization)
  width        Int?                          // pixels (images only)
  height       Int?                          // pixels (images only)
  uploadedBy   Int?                          // userId
  createdAt    DateTime @default(now())

  @@map("media")
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

model Webhook {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  secret    String?  // HMAC-SHA256 signing key — sent as X-NodePress-Signature header
  events    Json     // string[] e.g. ["entry.created","entry.updated","*"]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?                         // null if action done via API key
  userEmail  String
  action     String                       // created | updated | deleted | restored | login
  resource   String                       // entry | content_type | user | api_key | form | media
  resourceId String                       // slug, id, or name identifying the record
  metadata   Json?                        // optional context (e.g. changed fields)
  ip         String?
  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([userId])
  @@map("audit_logs")
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique               // 64 hex chars (32 random bytes)
  expiresAt DateTime                       // 15 minutes from creation
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Forms Module ────────────────────────────────────────────────────────────

model Form {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique  // used in public submit endpoint: POST /api/submit/:slug
  fields      Json             // FieldDef[]  — see forms/types/form-field.types.ts
  actions     Json             @default("[]") // ActionDef[] — email | webhook
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId    Int
  data      Json     // validated key→value pairs
  ip        String?  // submitter IP (optional, for spam detection)
  createdAt DateTime @default(now())

  @@map("form_submissions")
}
