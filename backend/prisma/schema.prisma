generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ContentType {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  schema         Json
  allowedMethods Json?    // null = all enabled. e.g. ["list","read","create","update","delete"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  entries        Entry[]
  schemaVersions ContentTypeSchemaVersion[]

  @@map("content_types")
}

model ContentTypeSchemaVersion {
  id            Int         @id @default(autoincrement())
  contentTypeId Int
  schema        Json        // snapshot of schema at time of change
  changedBy     Int?        // userId — null if changed via API key or system
  createdAt     DateTime    @default(now())
  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@index([contentTypeId])
  @@index([createdAt(sort: Desc)])
  @@map("content_type_schema_versions")
}

model Entry {
  id            Int            @id @default(autoincrement())
  publicId      String         @unique @default(uuid())   // public-facing UUID v4 — exposed as "id" in API
  slug          String
  locale        String         @default("en")             // BCP 47 locale code e.g. "en", "fr", "de"
  status        String         @default("published")       // draft | published | archived
  data          Json
  contentType   ContentType    @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  contentTypeId Int
  seo           Json?                                      // { title?, description?, image?, noIndex? }
  publishAt     DateTime?                                  // if set and in the past → auto-published by cron
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?                                  // null = active; set on soft delete
  versions      EntryVersion[]

  @@unique([contentTypeId, slug, locale])
  @@index([contentTypeId])
  @@index([locale])
  @@index([status])
  @@index([deletedAt])
  @@index([publishAt])
  @@index([createdAt])
  @@index([contentTypeId, status, deletedAt])   // public API: WHERE contentTypeId=? AND status='published' AND deletedAt IS NULL
  @@map("entries")
}

model EntryVersion {
  id        Int      @id @default(autoincrement())
  entryId   Int
  slug      String
  data      Json
  status    String
  createdBy Int?     // userId who triggered the update
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@map("entry_versions")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  key         String    @unique
  permissions Json      // { access: "read"|"write"|"all", contentTypes: string[]|"*" }
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@map("api_keys")
}

// ─── Media Library ───────────────────────────────────────────────────────────

// ─── Media Library ───────────────────────────────────────────────────────────

model MediaFolder {
  id        Int           @id @default(autoincrement())
  name      String
  parentId  Int?                                   // null = root folder
  parent    MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("FolderTree")
  media     Media[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([parentId, name])                       // unique name within the same parent
  @@index([parentId])
  @@map("media_folders")
}

model Media {
  id           Int          @id @default(autoincrement())
  filename     String       @unique              // stored filename / S3 key
  webpFilename String?                           // WebP version key (images only)
  url          String                            // public URL
  webpUrl      String?                           // WebP version URL
  originalName String                            // original upload filename
  mimetype     String
  size         Int                               // bytes (after optimization)
  width        Int?                              // pixels (images only)
  height       Int?                              // pixels (images only)
  uploadedBy   Int?                              // userId
  folderId     Int?                              // null = root / unfiled
  folder       MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())

  @@index([folderId])
  @@map("media")
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

model WebhookDelivery {
  id             Int       @id @default(autoincrement())
  webhookId      Int
  event          String
  payload        Json
  status         String    @default("pending")  // pending | delivered | failed
  attempts       Int       @default(0)
  nextRetryAt    DateTime?                       // null = done (delivered or max retries hit)
  responseStatus Int?                           // HTTP status from recipient
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextRetryAt])
  @@index([webhookId])
  @@map("webhook_deliveries")
}

model Webhook {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  secret    String?  // HMAC-SHA256 signing key — sent as X-NodePress-Signature header
  events    Json     // string[] e.g. ["entry.created","entry.updated","*"]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?                         // null if action done via API key
  userEmail  String
  action     String                       // created | updated | deleted | restored | login
  resource   String                       // entry | content_type | user | api_key | form | media
  resourceId String                       // slug, id, or name identifying the record
  metadata   Json?                        // optional context (e.g. changed fields)
  ip         String?
  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([resource, createdAt(sort: Desc)])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── Permissions ─────────────────────────────────────────────────────────────

model Permission {
  id          Int      @id @default(autoincrement())
  role        String   // 'editor' | 'viewer' | 'contributor'
  contentType String   // '*' = all content types, or specific name e.g. 'article'
  actions     String[] // subset of: create, read, update, delete, publish

  @@unique([role, contentType])
  @@index([role])
  @@map("permissions")
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique              // 64 hex chars (32 random bytes)
  expiresAt DateTime                      // 30 days from creation
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique               // 64 hex chars (32 random bytes)
  expiresAt DateTime                       // 15 minutes from creation
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Forms Module ────────────────────────────────────────────────────────────

model Form {
  id             Int              @id @default(autoincrement())
  name           String
  slug           String           @unique  // used in public submit endpoint: POST /api/submit/:slug
  fields         Json             // FieldDef[]  — see forms/types/form-field.types.ts
  actions        Json             @default("[]") // ActionDef[] — email | webhook
  isActive       Boolean          @default(true)
  captchaEnabled Boolean          @default(false) // require captcha token on submit (needs CAPTCHA_PROVIDER env)
  successMessage String?          // shown after successful submission (null = default message)
  redirectUrl    String?          // optional URL returned to client after successful submission
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  submissions    FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId    Int
  data      Json     // validated key→value pairs
  ip        String?  // submitter IP (optional, for spam detection)
  createdAt DateTime @default(now())

  @@index([formId])
  @@index([formId, createdAt(sort: Desc)])
  @@map("form_submissions")
}
