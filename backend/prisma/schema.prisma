generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContentType {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  schema         Json
  allowedMethods Json?    // null = all enabled. e.g. ["list","read","create","update","delete"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  entries        Entry[]

  @@map("content_types")
}

model Entry {
  id            Int         @id @default(autoincrement())
  slug          String
  data          Json
  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  contentTypeId Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([contentTypeId, slug])
  @@map("entries")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  key         String    @unique
  permissions Json      // { access: "read"|"write"|"all", contentTypes: string[]|"*" }
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@map("api_keys")
}

// ─── Forms Module ────────────────────────────────────────────────────────────

model Form {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique  // used in public submit endpoint: POST /api/submit/:slug
  fields      Json             // FieldDef[]  — see forms/types/form-field.types.ts
  actions     Json             @default("[]") // ActionDef[] — email | webhook
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId    Int
  data      Json     // validated key→value pairs
  ip        String?  // submitter IP (optional, for spam detection)
  createdAt DateTime @default(now())

  @@map("form_submissions")
}
