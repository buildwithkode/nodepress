# NodePress Frontend — copy to .env.local and fill in your values
# The CLI (npx create-nodepress-app) generates this automatically.

# ── Required ──────────────────────────────────────────────────────────────────

# URL of your NodePress backend (used by server components only — never exposed to the browser)
# In development this defaults to http://localhost:3000 if not set.
# In production set this to your actual backend URL (e.g. https://api.yourdomain.com)
BACKEND_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────

# Public URL of this site — used as metadataBase for SEO (absolute canonical and
# OG/Twitter image URLs on public pages). Defaults to http://localhost:5173 in dev.
# In production set to your public site origin (e.g. https://www.yourdomain.com).
# SITE_URL=https://www.yourdomain.com

# Sentry error tracking DSN (leave blank to disable)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
