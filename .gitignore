backend/dist/
frontend/.next/
frontend/out/

# Prisma migrations are safe to commit — do NOT ignore them

# Uploads (keep folder, ignore files)
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
